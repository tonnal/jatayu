# Copy to .env and fill in. .env is gitignored.

# Coresignal Clean Employee API
CORESIGNAL_API_KEY=

# LLM scoring + outreach (Anthropic by default)
ANTHROPIC_API_KEY=
JATAYU_SCORING_MODEL=claude-opus-4-7

# Safety rails — the engine refuses to spend more than this many collect
# credits in a single run unless overridden on the CLI. Protects the 300 trial.
JATAYU_CREDIT_HARD_CAP=250
